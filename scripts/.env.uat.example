# Variables d'environnement pour le serveur UAT EVE Pilot.
# Copier ce fichier en .env (a la racine du projet) avant de lancer run_uat.ps1.
# NE JAMAIS committer le vrai .env (deja gitignore).

# --- Django ---
# Generer une nouvelle SECRET_KEY pour l'UAT (jamais la meme que le dev local).
# Methode rapide :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=GENERER-UNE-NOUVELLE-CLE-50-CARACTERES

# CRITIQUE pour l'UAT : DEBUG=False (sinon les tracebacks et la SECRET_KEY
# peuvent fuiter dans le navigateur).
DJANGO_DEBUG=False

# Liste les hostnames / IP d'ou les testeurs vont se connecter. Remplacer
# 192.168.1.42 par l'IP LAN reelle de cette machine (ipconfig).
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.42,nom-de-ce-pc.local

# Requis quand DEBUG=False pour les POST (login, formulaires) depuis ces origines.
# Meme principe : remplacer l'IP par la vraie.
DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.1.42:8000,http://nom-de-ce-pc.local:8000

# URL de base utilisee dans les emails (liens absolus vers les demandes).
SITE_BASE_URL=http://192.168.1.42:8000

# --- Base UAT ---
# Pointe vers la base cloneee, PAS la base de dev.
POSTGRES_DB=eve_pilot_uat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=eve_pilot_dev
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5434

# --- Email ---
# En UAT, on laisse le backend console par defaut : pas de vrai mail envoye
# aux testeurs (sinon la DP recoit 30 mails par jour pendant les tests).
# Pour envoyer reellement, decommenter la ligne suivante.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=vps75468.serveur-vps.net
EMAIL_PORT=465
EMAIL_USE_SSL=True
# EMAIL_HOST_USER=alydiouf@eve-sn.org
# EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=EVE Pilot UAT <no-reply@eve-sn.org>
