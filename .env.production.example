# MODELE .env de PRODUCTION — copier en .env sur le VPS et remplir.
# Ne JAMAIS committer le vrai .env (il est dans .gitignore).
# Permissions recommandees sur le VPS : chmod 600 .env

# --- Django ---
# Generer une cle unique :  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=REMPLACER_PAR_UNE_CLE_ALEATOIRE_LONGUE
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=pilot.eve-sn.org
DJANGO_CSRF_TRUSTED_ORIGINS=https://pilot.eve-sn.org

# Securite production (HTTPS derriere reverse proxy) — laisser True en ligne.
DJANGO_PROD_SECURITY=True
# Medias : False = Django streame les fichiers lui-meme (login obligatoire),
# compatible Apache ET nginx (cas ISPConfig). Passer a True uniquement si le
# reverse proxy est nginx ET que la location internal X-Accel est configuree.
DJANGO_X_ACCEL_REDIRECT=False
# HSTS : 2592000 = 30 jours pour le test ; passer a 31536000 (1 an) une fois stable.
DJANGO_HSTS_SECONDS=2592000

# --- Base de donnees PostgreSQL ---
POSTGRES_DB=eve_pilot
POSTGRES_USER=eve_pilot
POSTGRES_PASSWORD=REMPLACER_PAR_UN_MOT_DE_PASSE_FORT
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# --- Email (SMTP EVE) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=vps75468.serveur-vps.net
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=no-reply@eve-sn.org
EMAIL_HOST_PASSWORD=REMPLACER
DEFAULT_FROM_EMAIL=EVE Pilot <no-reply@eve-sn.org>
EMAIL_TIMEOUT=10

# Liens absolus dans les emails.
SITE_BASE_URL=https://pilot.eve-sn.org
